APP_NAME="Plantix AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Multi-panel URLs ─────────────────────────────────────────────────────
# ADMIN_URL=http://localhost:8000/admin
# VENDOR_URL=http://localhost:8000/vendor

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (MySQL) ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plantix_ai
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache & Session ──────────────────────────────────────────────────────
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@plantix.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (optional — for image storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Pusher / Soketi (WebSocket broadcasting — replaces Firebase Realtime) ───
# Use Pusher SaaS credentials, or run Soketi locally: npx soketi start
PUSHER_APP_ID=your-app-id
PUSHER_APP_KEY=your-app-key
PUSHER_APP_SECRET=your-app-secret
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─── Firebase (FCM push notifications ONLY — Firestore auth REMOVED) ─────────
# Keep ONLY for sending push via FCM HTTP v1 API.
# Place your Google service-account JSON at:  storage/app/firebase/credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=

RAZORPAY_KEY=
RAZORPAY_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=

# ─── Google Maps (for zone polygon display) ──────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Plantix AI Custom Config ─────────────────────────────────────────────────
PLANTIX_TAX_RATE=0.0
PLANTIX_CURRENCY_CODE=PKR
PLANTIX_CURRENCY_SYMBOL=Rs
PLANTIX_LOW_STOCK_THRESHOLD=10
PLANTIX_CART_MAX_ITEMS=50
PLANTIX_FEATURED_COUNT=8
PLANTIX_APPOINTMENTS_PER_DAY=10
PLANTIX_ADMIN_COMMISSION=10.0
PLANTIX_WALLET_VALIDITY=365

# ─── Laravel Sanctum ─────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── Sanctum (API token auth) ────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1
